<?xml version="1.0" encoding="utf-8"?>
<!-- Court card: available (green left accent) -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/card_background" />
            <corners android:radius="@dimen/radius_lg" />
        </shape>
    </item>
    <item android:right="0dp" android:top="0dp" android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/status_available" />
            <corners
                android:topLeftRadius="@dimen/radius_lg"
                android:bottomLeftRadius="@dimen/radius_lg"
                android:topRightRadius="0dp"
                android:bottomRightRadius="0dp" />
            <size android:width="4dp" />
        </shape>
    </item>
</layer-list>
