<?xml version="1.0" encoding="utf-8"?>
<!-- Màn hình Cấu hình sân — activity_cau_hinh_san.xml -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- TOOLBAR -->
    <LinearLayout
        android:id="@+id/layoutToolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/top_app_bar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_sm"
        android:paddingEnd="@dimen/margin_mobile"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/text_primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_sm"
            android:text="@string/title_cau_hinh_san"
            android:textSize="@dimen/text_title_lg"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />

        <!-- Add court button -->
        <ImageButton
            android:id="@+id/btnThemSan"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_input_add"
            app:tint="@color/primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:contentDescription="Add court" />
    </LinearLayout>

    <!-- SCROLL -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/layoutToolbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_mobile">

            <!-- ADD COURT FORM CARD -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardThemSan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <!-- Header with icon -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_circle_green"
                            android:layout_marginEnd="@dimen/spacing_md">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_input_add"
                                app:tint="@color/primary" />
                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/title_them_san_moi"
                            android:textSize="@dimen/text_title_lg"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Tên sân -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/hint_ten_san"
                        android:textSize="@dimen/text_body_md"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <EditText
                        android:id="@+id/etTenSan"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_default"
                        android:paddingStart="@dimen/input_padding_horizontal"
                        android:paddingEnd="@dimen/input_padding_horizontal"
                        android:hint="VD: Sân 01"
                        android:textSize="@dimen/text_body_lg"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:inputType="text"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- Loại sân -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/hint_loai_san"
                        android:textSize="@dimen/text_body_md"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <EditText
                        android:id="@+id/etLoaiSan"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_default"
                        android:paddingStart="@dimen/input_padding_horizontal"
                        android:paddingEnd="@dimen/input_padding_horizontal"
                        android:hint="Cỏ nhân tạo, Gỗ, ..."
                        android:textSize="@dimen/text_body_lg"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:inputType="text"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- Giá mặc định -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/hint_gia_mac_dinh"
                        android:textSize="@dimen/text_body_md"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <EditText
                        android:id="@+id/etGiaMacDinh"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_default"
                        android:paddingStart="@dimen/input_padding_horizontal"
                        android:paddingEnd="@dimen/input_padding_horizontal"
                        android:hint="70,000"
                        android:textSize="@dimen/text_body_lg"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:inputType="numberDecimal"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- Mô tả -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/hint_mo_ta"
                        android:textSize="@dimen/text_body_md"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <EditText
                        android:id="@+id/etMoTa"
                        android:layout_width="match_parent"
                        android:layout_height="80dp"
                        android:background="@drawable/bg_input_default"
                        android:paddingStart="@dimen/input_padding_horizontal"
                        android:paddingEnd="@dimen/input_padding_horizontal"
                        android:paddingTop="@dimen/spacing_md"
                        android:hint="Mô tả thêm về sân..."
                        android:textSize="@dimen/text_body_lg"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:inputType="textMultiLine"
                        android:gravity="top"
                        android:maxLines="3"
                        android:layout_marginBottom="@dimen/spacing_lg" />

                    <!-- Action Buttons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="2">

                        <Button
                            android:id="@+id/btnHuy"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/button_height"
                            android:layout_weight="1"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:background="@drawable/bg_btn_secondary"
                            android:text="@string/btn_huy"
                            android:textColor="@color/background"
                            android:textSize="@dimen/text_body_md"
                            android:textStyle="bold"
                            android:stateListAnimator="@null" />

                        <Button
                            android:id="@+id/btnLuuSan"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/button_height"
                            android:layout_weight="1"
                            android:layout_marginStart="@dimen/spacing_sm"
                            android:background="@drawable/bg_btn_primary"
                            android:text="@string/btn_luu_san"
                            android:textColor="@color/white"
                            android:textSize="@dimen/text_body_md"
                            android:textStyle="bold"
                            android:stateListAnimator="@null" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- SECTION: Danh sách sân hiện tại -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Danh sách sân"
                android:textSize="@dimen/text_label_md"
                android:textColor="@color/text_hint"
                android:textAllCaps="true"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <!-- Court list item 1 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardCourtItem1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:visibility="gone"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding"
                    android:gravity="center_vertical">

                    <FrameLayout
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_icon_circle_green"
                        android:layout_marginEnd="@dimen/spacing_md">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="01"
                            android:textSize="@dimen/text_body_md"
                            android:textColor="@color/primary"
                            android:textStyle="bold" />
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvCourt1Name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sân 01"
                            android:textSize="@dimen/text_body_lg"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvCourt1Type"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cỏ nhân tạo • 70,000 VNĐ/h"
                            android:textSize="@dimen/text_body_md"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <!-- Edit / Delete actions -->
                    <ImageButton
                        android:id="@+id/btnEditCourt1"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_menu_edit"
                        app:tint="@color/primary"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="6dp"
                        android:contentDescription="Edit" />

                    <ImageButton
                        android:id="@+id/btnDeleteCourt1"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:src="@android:drawable/ic_menu_delete"
                        app:tint="@color/secondary"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:padding="6dp"
                        android:contentDescription="Delete" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ListView dung adapter rieng giong cau truc bai hoc Buoi 8 -->
            <ListView
                android:id="@+id/lvDanhSachSan"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:divider="@android:color/transparent"
                android:dividerHeight="0dp"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
