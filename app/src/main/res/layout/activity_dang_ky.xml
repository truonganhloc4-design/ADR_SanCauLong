<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F8FC"
    android:fitsSystemWindows="true">

    <FrameLayout
        android:id="@+id/headerRegister"
        android:layout_width="0dp"
        android:layout_height="188dp"
        android:background="@drawable/bg_login_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="18dp"
            android:layout_marginTop="12dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Quay lại"
            android:padding="10dp"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/white" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="18dp">

            <androidx.cardview.widget.CardView
                android:layout_width="128dp"
                android:layout_height="54dp"
                app:cardCornerRadius="6dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@color/white">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:adjustViewBounds="true"
                    android:padding="8dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/img_1" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Tạo tài khoản"
                android:textColor="@color/white"
                android:textSize="23sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="Dành cho nhân viên hoặc người quản lý sân."
                android:textColor="#DDEBFF"
                android:textSize="13sp" />
        </LinearLayout>
    </FrameLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerRegister"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="16dp"
            android:paddingBottom="28dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="22dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_xs"
                        android:text="Tên hiển thị"
                        android:textColor="#062642"
                        android:textSize="@dimen/text_body_md"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginBottom="@dimen/spacing_md"
                        android:background="@drawable/bg_input_default"
                        android:clickable="true"
                        android:focusable="false"
                        android:gravity="center_vertical|start"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/input_padding_horizontal"
                        android:paddingEnd="@dimen/input_padding_horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:src="@android:drawable/ic_menu_myplaces"
                            app:tint="#A3A3A3" />

                        <EditText
                            android:id="@+id/etDisplayName"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:gravity="center_vertical|start"
                            android:hint="Nguyễn Văn A"
                            android:imeOptions="actionNext"
                            android:inputType="textPersonName"
                            android:maxLines="1"
                            android:padding="0dp"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textCursorDrawable="@null"
                            android:textSize="@dimen/text_body_lg" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_xs"
                        android:text="Tên đăng nhập"
                        android:textColor="#062642"
                        android:textSize="@dimen/text_body_md"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginBottom="@dimen/spacing_md"
                        android:background="@drawable/bg_input_default"
                        android:clickable="true"
                        android:focusable="false"
                        android:gravity="center_vertical|start"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/input_padding_horizontal"
                        android:paddingEnd="@dimen/input_padding_horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:src="@android:drawable/ic_menu_edit"
                            app:tint="#A3A3A3" />

                        <EditText
                            android:id="@+id/etUsername"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:gravity="center_vertical|start"
                            android:hint="ten_dang_nhap"
                            android:imeOptions="actionNext"
                            android:inputType="textNoSuggestions|textVisiblePassword"
                            android:maxLines="1"
                            android:padding="0dp"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textCursorDrawable="@null"
                            android:textSize="@dimen/text_body_lg" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_xs"
                        android:text="Mật khẩu"
                        android:textColor="#062642"
                        android:textSize="@dimen/text_body_md"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginBottom="@dimen/spacing_md"
                        android:background="@drawable/bg_input_default"
                        android:clickable="true"
                        android:focusable="false"
                        android:gravity="center_vertical|start"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/input_padding_horizontal"
                        android:paddingEnd="@dimen/input_padding_horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:src="@android:drawable/ic_lock_lock"
                            app:tint="@color/error" />

                        <EditText
                            android:id="@+id/etPassword"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:gravity="center_vertical|start"
                            android:hint="Nhập mật khẩu"
                            android:imeOptions="actionNext"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:padding="0dp"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textCursorDrawable="@null"
                            android:textSize="@dimen/text_body_lg" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_xs"
                        android:text="Nhập lại mật khẩu"
                        android:textColor="#062642"
                        android:textSize="@dimen/text_body_md"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_default"
                        android:clickable="true"
                        android:focusable="false"
                        android:gravity="center_vertical|start"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/input_padding_horizontal"
                        android:paddingEnd="@dimen/input_padding_horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:src="@android:drawable/ic_lock_lock"
                            app:tint="@color/error" />

                        <EditText
                            android:id="@+id/etConfirmPassword"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:gravity="center_vertical|start"
                            android:hint="Nhập lại mật khẩu"
                            android:imeOptions="actionDone"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:padding="0dp"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textCursorDrawable="@null"
                            android:textSize="@dimen/text_body_lg" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvRegisterError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:minHeight="20dp"
                        android:textColor="@color/error"
                        android:textSize="@dimen/text_label_md"
                        android:visibility="invisible" />

                    <Button
                        android:id="@+id/btnRegister"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:background="@drawable/bg_login_button"
                        android:stateListAnimator="@null"
                        android:text="Đăng ký"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_body_lg"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvGoLogin"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:gravity="center"
                        android:text="Đã có tài khoản? Đăng nhập"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_body_md"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
