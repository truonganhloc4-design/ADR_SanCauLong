<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F6F8FC"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/headerLogin"
        android:layout_width="0dp"
        android:layout_height="224dp"
        android:background="@drawable/bg_login_header"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="18dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="82dp"
            app:cardCornerRadius="@dimen/radius_lg"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/white">

            <ImageView
                android:id="@+id/imgBrandBanner"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:adjustViewBounds="true"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:scaleType="fitCenter"
                android:src="@drawable/img_1" />
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Quản lý sân cầu lông"
            android:textColor="@color/white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Theo dõi sân, đặt lịch và thanh toán nhanh."
            android:textColor="#DDEBFF"
            android:textSize="13sp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/headerLogin"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:paddingTop="16dp"
            android:paddingBottom="28dp">

            <androidx.cardview.widget.CardView
                android:id="@+id/cardLoginForm"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="22dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="22dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:layout_marginBottom="22dp">

                        <androidx.cardview.widget.CardView
                            android:layout_width="62dp"
                            android:layout_height="62dp"
                            app:cardCornerRadius="@dimen/radius_md"
                            app:cardElevation="1dp"
                            app:cardBackgroundColor="@color/white">

                            <ImageView
                                android:id="@+id/imgLogo"
                                android:layout_width="56dp"
                                android:layout_height="56dp"
                                android:layout_gravity="center"
                                android:scaleType="fitCenter"
                                android:src="@drawable/logo" />
                        </androidx.cardview.widget.CardView>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="14dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvAppName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Chào mừng trở lại"
                                android:textColor="@color/text_primary"
                                android:textSize="21sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvAppSubtitle"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="3dp"
                                android:text="Đăng nhập tài khoản quản lý"
                                android:textColor="@color/text_secondary"
                                android:textSize="@dimen/text_body_md" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_xs"
                        android:text="Tên đăng nhập"
                        android:textColor="#062642"
                        android:textSize="@dimen/text_body_md"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:layout_marginBottom="@dimen/spacing_md"
                        android:background="@drawable/bg_input_default"
                        android:focusable="false"
                        android:gravity="center_vertical|start"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/input_padding_horizontal"
                        android:paddingEnd="@dimen/input_padding_horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:src="@android:drawable/ic_menu_myplaces"
                            app:tint="#A3A3A3" />

                        <EditText
                            android:id="@+id/etUsername"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:gravity="center_vertical|start"
                            android:hint="admin"
                            android:imeOptions="actionNext"
                            android:inputType="textNoSuggestions|textVisiblePassword"
                            android:maxLines="1"
                            android:padding="0dp"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textSize="@dimen/text_body_lg" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/spacing_xs"
                        android:text="Mật khẩu"
                        android:textColor="#062642"
                        android:textSize="@dimen/text_body_md"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_default"
                        android:focusable="false"
                        android:gravity="center_vertical|start"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/input_padding_horizontal"
                        android:paddingEnd="@dimen/input_padding_horizontal">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:src="@android:drawable/ic_lock_lock"
                            app:tint="@color/error" />

                        <EditText
                            android:id="@+id/etPassword"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:gravity="center_vertical|start"
                            android:hint="123"
                            android:imeOptions="actionDone"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:padding="0dp"
                            android:singleLine="true"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textSize="@dimen/text_body_lg" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tvLoginError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:minHeight="20dp"
                        android:textColor="@color/error"
                        android:textSize="@dimen/text_label_md"
                        android:visibility="invisible" />

                    <Button
                        android:id="@+id/btnLogin"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/button_height"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:background="@drawable/bg_login_button"
                        android:stateListAnimator="@null"
                        android:text="Đăng nhập"
                        android:textColor="@color/white"
                        android:textSize="@dimen/text_body_lg"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvGoRegister"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:gravity="center"
                        android:text="Chưa có tài khoản? Đăng ký"
                        android:textColor="@color/primary"
                        android:textSize="@dimen/text_body_md"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:background="@drawable/bg_login_hint"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:src="@android:drawable/ic_dialog_info"
                            app:tint="#F97316" />

                        <TextView
                            android:id="@+id/tvDefaultAccount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Tài khoản demo: admin / 123"
                            android:textColor="#9A3412"
                            android:textSize="@dimen/text_label_md"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
