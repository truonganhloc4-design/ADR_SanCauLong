<?xml version="1.0" encoding="utf-8"?>
<!-- Màn hình Đăng nhập — activity_dang_nhap.xml -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- ===== HEADER GRADIENT BANNER ===== -->
    <View
        android:id="@+id/viewHeaderBg"
        android:layout_width="0dp"
        android:layout_height="280dp"
        android:background="@drawable/bg_header_gradient"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- App Icon circle -->
    <FrameLayout
        android:id="@+id/frameAppIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:background="@drawable/bg_icon_circle_green"
        android:elevation="4dp"
        app:layout_constraintTop_toTopOf="@id/viewHeaderBg"
        app:layout_constraintBottom_toBottomOf="@id/viewHeaderBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.45">

        <ImageView
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_menu_compass"
            app:tint="@color/primary" />
    </FrameLayout>

    <!-- App Name -->
    <TextView
        android:id="@+id/tvAppName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_name"
        android:textSize="@dimen/text_headline_md"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/frameAppIcon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Subtitle -->
    <TextView
        android:id="@+id/tvAppSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/login_welcome"
        android:textSize="@dimen/text_body_md"
        android:textColor="#CCffffff"
        android:layout_marginTop="4dp"
        app:layout_constraintTop_toBottomOf="@id/tvAppName"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- ===== FORM CARD ===== -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardLoginForm"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/margin_mobile"
        android:layout_marginEnd="@dimen/margin_mobile"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="@dimen/radius_xl"
        app:cardElevation="8dp"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintTop_toBottomOf="@id/viewHeaderBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintVertical_bias="0.05">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_lg">

            <!-- Login Title -->
            <TextView
                android:id="@+id/tvLoginTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_login"
                android:textSize="@dimen/text_headline_sm"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/tvLoginSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/login_subtitle"
                android:textSize="@dimen/text_body_md"
                android:textColor="@color/text_secondary"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <!-- Username field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_username"
                android:textSize="@dimen/text_body_md"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <EditText
                android:id="@+id/etUsername"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:background="@drawable/bg_input_default"
                android:paddingStart="@dimen/input_padding_horizontal"
                android:paddingEnd="@dimen/input_padding_horizontal"
                android:hint="@string/hint_username"
                android:textSize="@dimen/text_body_lg"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:inputType="text"
                android:singleLine="true"
                android:drawableStart="@android:drawable/ic_menu_myplaces"
                android:drawablePadding="10dp"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Password field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hint_password"
                android:textSize="@dimen/text_body_md"
                android:textColor="@color/text_secondary"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="@dimen/input_height"
                android:background="@drawable/bg_input_default"
                android:paddingStart="@dimen/input_padding_horizontal"
                android:paddingEnd="@dimen/input_padding_horizontal"
                android:hint="@string/hint_password"
                android:textSize="@dimen/text_body_lg"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:inputType="textPassword"
                android:singleLine="true"
                android:drawableStart="@android:drawable/ic_lock_lock"
                android:drawablePadding="10dp"
                android:layout_marginBottom="@dimen/spacing_lg" />

            <!-- Error message -->
            <TextView
                android:id="@+id/tvLoginError"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textSize="@dimen/text_body_md"
                android:textColor="@color/error"
                android:visibility="gone"
                android:layout_marginBottom="@dimen/spacing_sm" />

            <!-- Login Button -->
            <Button
                android:id="@+id/btnLogin"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:background="@drawable/bg_btn_primary"
                android:text="@string/btn_login"
                android:textColor="@color/white"
                android:textSize="@dimen/text_body_lg"
                android:textStyle="bold"
                android:stateListAnimator="@null"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Default account hint -->
            <TextView
                android:id="@+id/tvDefaultAccount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/default_account"
                android:textSize="@dimen/text_label_md"
                android:textColor="@color/text_hint"
                android:layout_gravity="center"
                android:gravity="center" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
