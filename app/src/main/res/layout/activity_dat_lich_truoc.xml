<?xml version="1.0" encoding="utf-8"?>
<!-- Màn hình Đặt lịch trước — activity_dat_lich_truoc.xml -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- TOOLBAR -->
    <LinearLayout
        android:id="@+id/layoutToolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/top_app_bar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_sm"
        android:paddingEnd="@dimen/margin_mobile"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/text_primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Đặt lịch trước"
            android:textSize="@dimen/text_title_lg"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:gravity="center" />
            
        <View
            android:layout_width="44dp"
            android:layout_height="44dp" />
    </LinearLayout>

    <!-- SCROLL CONTENT -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/layoutToolbar"
        app:layout_constraintBottom_toTopOf="@id/layoutActionBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_mobile">

            <!-- CARD: Thông tin khách hàng -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin khách hàng"
                        android:textSize="@dimen/text_title_lg"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="16dp" />

                    <!-- Tên khách hàng -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tên khách hàng"
                        android:textSize="@dimen/text_label_md"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_default"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="@dimen/input_padding_horizontal"
                        android:layout_marginBottom="12dp">
                        
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_myplaces"
                            app:tint="@color/text_hint"
                            android:layout_marginEnd="8dp" />

                        <EditText
                            android:id="@+id/etHoTen"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Nhập tên khách hàng"
                            android:textSize="@dimen/text_body_lg"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:inputType="textPersonName" />
                    </LinearLayout>

                    <!-- Số điện thoại -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số điện thoại"
                        android:textSize="@dimen/text_label_md"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_default"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="@dimen/input_padding_horizontal"
                        android:layout_marginBottom="12dp">
                        
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_call"
                            app:tint="@color/text_hint"
                            android:layout_marginEnd="8dp" />

                        <EditText
                            android:id="@+id/etSoDienThoai"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Nhập số điện thoại"
                            android:textSize="@dimen/text_body_lg"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:inputType="phone" />
                    </LinearLayout>

                    <!-- Tiền cọc -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tiền cọc (VNĐ)"
                        android:textSize="@dimen/text_label_md"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="4dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_default"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="@dimen/input_padding_horizontal">
                        
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@android:drawable/ic_menu_sort_by_size"
                            app:tint="@color/text_hint"
                            android:layout_marginEnd="8dp" />

                        <EditText
                            android:id="@+id/etTienCoc"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:text="0"
                            android:textSize="@dimen/text_body_lg"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:inputType="numberDecimal" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- CARD: Chi tiết đặt sân -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chi tiết đặt sân"
                        android:textSize="@dimen/text_title_lg"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"
                        android:layout_marginBottom="16dp" />

                    <!-- Hàng ngang: Ngày & Giờ -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:baselineAligned="false"
                        android:layout_marginBottom="16dp">

                        <!-- Ngày đặt lịch -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginEnd="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Ngày đặt lịch"
                                android:textSize="@dimen/text_label_md"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:layout_marginBottom="4dp" />

                            <LinearLayout
                                android:id="@+id/btnChonNgay"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/input_height"
                                android:background="@drawable/bg_input_default"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp">

                                <TextView
                                    android:id="@+id/tvNgayDuocChon"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="18/05/2026"
                                    android:textSize="@dimen/text_body_lg"
                                    android:textColor="@color/text_primary" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Khung giờ chơi -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="8dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Khung giờ chơi"
                                android:textSize="@dimen/text_label_md"
                                android:textStyle="bold"
                                android:textColor="@color/text_secondary"
                                android:layout_marginBottom="4dp" />

                            <LinearLayout
                                android:id="@+id/btnChonKhungGio"
                                android:layout_width="match_parent"
                                android:layout_height="@dimen/input_height"
                                android:background="@drawable/bg_input_default"
                                android:orientation="horizontal"
                                android:gravity="center_vertical"
                                android:paddingStart="12dp"
                                android:paddingEnd="12dp">

                                <TextView
                                    android:id="@+id/tvKhungGioDuocChon"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="18:00 - 20:00"
                                    android:textSize="@dimen/text_body_lg"
                                    android:textColor="@color/text_primary" />

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@android:drawable/arrow_down_float"
                                    app:tint="@color/text_hint" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Số sân muốn đặt (Grid) -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số sân muốn đặt"
                        android:textSize="@dimen/text_label_md"
                        android:textStyle="bold"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="8dp" />

                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="3"
                        android:rowCount="2">

                        <TextView
                            android:id="@+id/btnSan1"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/button_height"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_chip_filter_active"
                            android:text="Sân 1"
                            android:textColor="#00105c"
                            android:textSize="@dimen/text_body_lg"
                            android:textStyle="bold"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/btnSan2"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/button_height"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_input_default"
                            android:text="Sân 2"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_body_lg"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/btnSan3"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/button_height"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_input_default"
                            android:text="Sân 3"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_body_lg"
                            android:gravity="center" />

                        <TextView
                            android:id="@+id/btnSan4"
                            android:layout_width="0dp"
                            android:layout_height="@dimen/button_height"
                            android:layout_columnWeight="1"
                            android:layout_margin="4dp"
                            android:background="@drawable/bg_input_default"
                            android:text="Sân 4"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_body_lg"
                            android:gravity="center" />
                    </GridLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM ACTION -->
    <LinearLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:paddingStart="@dimen/margin_mobile"
        android:paddingEnd="@dimen/margin_mobile"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_md"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnXacNhanDatLich"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:background="@drawable/bg_btn_primary"
            android:text="XÁC NHẬN ĐẶT LỊCH"
            android:textColor="@color/white"
            android:textSize="@dimen/text_title_lg"
            android:textStyle="bold"
            android:stateListAnimator="@null" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
