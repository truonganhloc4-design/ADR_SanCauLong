<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- HEADER (luôn hiển thị) -->
    <FrameLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="@color/primary"
                android:layout_marginEnd="16dp" />

            <TextView
                android:id="@+id/tvFacilityName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sơ đồ sân"
                android:textSize="20sp"
                android:textColor="@color/primary"
                android:textStyle="bold" />

            <!-- Nút Cấu hình sân (thay bằng icon stats/bar chart) -->
            <ImageView
                android:id="@+id/ivCauHinhSan"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="@color/primary"
                android:layout_marginEnd="16dp"
                android:contentDescription="Thêm sân" />

            <!-- Avatar -->
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_gallery"
                android:background="@drawable/bg_icon_circle_blue"
                android:padding="4dp"
                app:tint="@color/white" />
        </LinearLayout>
    </FrameLayout>

    <!-- FRAGMENT CONTAINER (chiếm toàn bộ không gian còn lại) -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <FrameLayout
            android:id="@+id/fragmentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <!-- FAB Thêm sân -->
        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fabThemSan"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="24dp"
            android:text="Thêm sân"
            android:textColor="@color/white"
            app:icon="@android:drawable/ic_input_add"
            app:iconTint="@color/white"
            app:backgroundTint="@color/primary"
            app:elevation="6dp" />
    </FrameLayout>

    <!-- BOTTOM NAVIGATION (luôn cố định ở dưới) -->
    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="@dimen/bottom_nav_height"
        android:orientation="horizontal"
        android:background="@color/white"
        android:weightSum="3"
        android:gravity="center_vertical"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/navSoDo"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <!-- Active indicator logic will be handled in code, but we provide base layout here -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/bg_icon_circle_blue"
                android:backgroundTint="#EBF0FF">
                <ImageView
                    android:id="@+id/iconSoDo"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_agenda"
                    app:tint="@color/primary" />
            </LinearLayout>

            <TextView
                android:id="@+id/labelSoDo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sơ đồ"
                android:textSize="12sp"
                android:textColor="@color/primary"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navThongKe"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/iconThongKe"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/labelThongKe"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thống kê"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navLichSu"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center">

            <ImageView
                android:id="@+id/iconLichSu"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@android:drawable/ic_menu_recent_history"
                app:tint="@color/text_secondary" />

            <TextView
                android:id="@+id/labelLichSu"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lịch sử"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="4dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
