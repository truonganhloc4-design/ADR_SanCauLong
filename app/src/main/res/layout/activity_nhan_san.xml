<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- TOOLBAR -->
    <LinearLayout
        android:id="@+id/layoutToolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/top_app_bar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_sm"
        android:paddingEnd="@dimen/margin_mobile"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/text_primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:contentDescription="Back" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/spacing_sm">

            <TextView
                android:id="@+id/tvToolbarTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/title_nhan_san"
                android:textSize="@dimen/text_title_lg"
                android:textColor="@color/text_primary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvCourtName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sân 01 • Cỏ nhân tạo"
                android:textSize="@dimen/text_body_md"
                android:textColor="@color/text_secondary" />
        </LinearLayout>
    </LinearLayout>

    <!-- SCROLL CONTENT -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/layoutToolbar"
        app:layout_constraintBottom_toTopOf="@id/layoutActionBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_mobile">

            <!-- Toggle Walk-in / Đặt trước -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_tab_container"
                android:padding="4dp"
                android:layout_marginBottom="@dimen/spacing_lg">

                <Button
                    android:id="@+id/btnWalkIn"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@drawable/bg_tab_active"
                    android:text="@string/label_walk_in"
                    android:textColor="@color/white"
                    android:textSize="@dimen/text_body_md"
                    android:textStyle="bold"
                    android:stateListAnimator="@null" />

                <Button
                    android:id="@+id/btnDatTruocTab"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:text="@string/label_dat_truoc_label"
                    android:textColor="@color/text_secondary"
                    android:textSize="@dimen/text_body_md"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- Card: Thông tin khách -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin khách hàng"
                        android:textSize="@dimen/text_title_lg"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_ten_khach"
                        android:textSize="@dimen/text_body_md"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <EditText
                        android:id="@+id/etTenKhach"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_default"
                        android:paddingStart="@dimen/input_padding_horizontal"
                        android:paddingEnd="@dimen/input_padding_horizontal"
                        android:hint="Họ và tên (tùy chọn)"
                        android:textSize="@dimen/text_body_lg"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:inputType="textPersonName"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_so_dien_thoai"
                        android:textSize="@dimen/text_body_md"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <EditText
                        android:id="@+id/etSoDienThoai"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_default"
                        android:paddingStart="@dimen/input_padding_horizontal"
                        android:paddingEnd="@dimen/input_padding_horizontal"
                        android:hint="0xxx xxx xxx"
                        android:textSize="@dimen/text_body_lg"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:inputType="phone" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Thời gian -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thời gian"
                        android:textSize="@dimen/text_title_lg"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_thoi_gian_bat_dau"
                        android:textSize="@dimen/text_body_md"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <LinearLayout
                        android:id="@+id/btnPickGioBatDau"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_default"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/input_padding_horizontal"
                        android:paddingEnd="@dimen/input_padding_horizontal"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <TextView
                            android:id="@+id/tvGioBatDau"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="14:30"
                            android:textSize="@dimen/text_body_lg"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <ImageView
                            android:layout_width="@dimen/icon_size"
                            android:layout_height="@dimen/icon_size"
                            android:src="@android:drawable/ic_menu_my_calendar"
                            app:tint="@color/primary" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/label_thoi_gian_ket_thuc"
                        android:textSize="@dimen/text_body_md"
                        android:textColor="@color/text_secondary"
                        android:layout_marginBottom="@dimen/spacing_sm" />

                    <LinearLayout
                        android:id="@+id/btnPickGioKetThuc"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_default"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingStart="@dimen/input_padding_horizontal"
                        android:paddingEnd="@dimen/input_padding_horizontal">

                        <TextView
                            android:id="@+id/tvGioKetThuc"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:hint="Chưa xác định"
                            android:textSize="@dimen/text_body_lg"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint" />

                        <ImageView
                            android:layout_width="@dimen/icon_size"
                            android:layout_height="@dimen/icon_size"
                            android:src="@android:drawable/ic_menu_my_calendar"
                            app:tint="@color/text_hint" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Giá thuê -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_gia_thue"
                            android:textSize="@dimen/text_title_lg"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/hint_khuyennghi"
                            android:textSize="@dimen/text_label_md"
                            android:textColor="@color/text_hint" />
                    </LinearLayout>

                    <EditText
                        android:id="@+id/etGiaThue"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_default"
                        android:paddingStart="@dimen/input_padding_horizontal"
                        android:paddingEnd="@dimen/input_padding_horizontal"
                        android:hint="70,000"
                        android:textSize="@dimen/text_headline_sm"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:inputType="numberDecimal"
                        android:textStyle="bold" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM ACTION -->
    <LinearLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:paddingStart="@dimen/margin_mobile"
        android:paddingEnd="@dimen/margin_mobile"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_md"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnXacNhanNhanSan"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:background="@drawable/bg_btn_primary"
            android:text="@string/btn_xac_nhan_nhan_san"
            android:textColor="@color/white"
            android:textSize="@dimen/text_body_lg"
            android:textStyle="bold"
            android:stateListAnimator="@null" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
