<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:id="@+id/layoutToolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/top_app_bar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_sm"
        android:paddingEnd="@dimen/margin_mobile"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/text_primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:contentDescription="Quay lại" />

        <TextView
            android:id="@+id/tvToolbarTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Nhận sân"
            android:textSize="@dimen/text_title_lg"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/layoutToolbar"
        app:layout_constraintBottom_toTopOf="@id/layoutActionBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_mobile">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@color/status_available" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/tvCourtName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Sân 01"
                                android:textSize="@dimen/text_title_lg"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/tvCourtStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="@dimen/chip_height"
                                android:background="@drawable/bg_chip_available"
                                android:gravity="center"
                                android:paddingStart="@dimen/chip_padding_horizontal"
                                android:paddingEnd="@dimen/chip_padding_horizontal"
                                android:text="Trống"
                                android:textColor="@color/status_available"
                                android:textSize="@dimen/text_label_md"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvCourtPrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/spacing_xs"
                            android:text="70.000 VND/gio"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_body_md" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Giờ bắt đầu"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_body_md"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:background="@drawable/bg_chip_filter_inactive"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:id="@+id/tvGioBatDau"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="14:30"
                            android:textColor="@color/text_primary"
                            android:textSize="28sp"
                            android:textStyle="bold" />

                        <ImageView
                            android:id="@+id/btnPickGioBatDau"
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_btn_secondary"
                            android:padding="12dp"
                            android:src="@android:drawable/ic_menu_recent_history"
                            app:tint="@color/primary" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thông tin khách"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_title_lg"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <LinearLayout
                        android:id="@+id/layoutKhachDatTruoc"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <TextView
                            android:id="@+id/tvKhachDatTruocLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Khách đặt trước"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_body_md"
                            android:textStyle="bold"
                            android:layout_marginBottom="@dimen/spacing_xs" />

                        <LinearLayout
                            android:id="@+id/btnChonKhachDatTruoc"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/input_height"
                            android:background="@drawable/bg_input_default"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="@dimen/input_padding_horizontal"
                            android:paddingEnd="@dimen/input_padding_horizontal">

                            <TextView
                                android:id="@+id/tvKhachDatTruocDuocChon"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:hint="Chọn khách đặt trước"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_hint"
                                android:textSize="@dimen/text_body_lg" />

                            <ImageView
                                android:layout_width="@dimen/icon_size"
                                android:layout_height="@dimen/icon_size"
                                android:src="@android:drawable/arrow_down_float"
                                app:tint="@color/text_hint" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tên khách hàng *"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_body_md"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/spacing_xs" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_default"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="@dimen/input_padding_horizontal"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:src="@android:drawable/ic_menu_myplaces"
                            app:tint="@color/text_hint" />

                        <EditText
                            android:id="@+id/etTenKhach"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Nhập tên khách hàng"
                            android:inputType="textPersonName"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textSize="@dimen/text_body_lg" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Số điện thoại"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_body_md"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/spacing_xs" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_default"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="@dimen/input_padding_horizontal"
                        android:layout_marginBottom="@dimen/spacing_md">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:src="@android:drawable/ic_menu_call"
                            app:tint="@color/text_hint" />

                        <EditText
                            android:id="@+id/etSoDienThoai"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:hint="Nhập số điện thoại"
                            android:inputType="phone"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textSize="@dimen/text_body_lg" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tiền cọc (VND)"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_body_md"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/spacing_xs" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/input_height"
                        android:background="@drawable/bg_input_default"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="12dp"
                        android:paddingEnd="@dimen/input_padding_horizontal">

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="@dimen/spacing_sm"
                            android:src="@android:drawable/ic_menu_save"
                            app:tint="@color/text_hint" />

                        <EditText
                            android:id="@+id/etTienCoc"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@null"
                            android:inputType="numberDecimal"
                            android:text="0"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:textSize="@dimen/text_body_lg" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:paddingStart="@dimen/margin_mobile"
        android:paddingEnd="@dimen/margin_mobile"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_md"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnHuy"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:background="@drawable/bg_btn_outlined"
            android:text="Hủy"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_body_lg"
            android:textStyle="bold"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnXacNhanNhanSan"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="2"
            android:layout_marginStart="@dimen/spacing_sm"
            android:background="@drawable/bg_btn_primary"
            android:text="Bắt đầu chơi"
            android:textColor="@color/white"
            android:textSize="@dimen/text_body_lg"
            android:textStyle="bold"
            android:stateListAnimator="@null" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
