<?xml version="1.0" encoding="utf-8"?>
<!-- Màn hình Thanh toán — activity_thanh_toan.xml -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- TOOLBAR -->
    <LinearLayout
        android:id="@+id/layoutToolbar"
        android:layout_width="0dp"
        android:layout_height="@dimen/top_app_bar_height"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/spacing_sm"
        android:paddingEnd="@dimen/margin_mobile"
        android:background="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@android:drawable/ic_media_previous"
            app:tint="@color/text_primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_sm"
            android:text="@string/title_thanh_toan"
            android:textSize="@dimen/text_title_lg"
            android:textColor="@color/text_primary"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- SCROLL -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/layoutToolbar"
        app:layout_constraintBottom_toTopOf="@id/layoutActionBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_mobile">

            <!-- Card: Booking info summary -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <View
                        android:layout_width="4dp"
                        android:layout_height="match_parent"
                        android:background="@color/primary_container" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/card_padding">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="@dimen/spacing_sm">

                            <TextView
                                android:id="@+id/tvCourtTitle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Sân 01 - Cỏ nhân tạo"
                                android:textSize="@dimen/text_title_lg"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="@dimen/chip_height"
                                android:background="@drawable/bg_chip_occupied"
                                android:paddingStart="@dimen/chip_padding_horizontal"
                                android:paddingEnd="@dimen/chip_padding_horizontal"
                                android:text="@string/status_occupied"
                                android:textSize="@dimen/text_label_md"
                                android:textColor="@color/status_occupied"
                                android:textStyle="bold"
                                android:gravity="center" />
                        </LinearLayout>

                        <!-- Mã ca -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="@dimen/spacing_xs">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_ma_ca"
                                android:textSize="@dimen/text_body_md"
                                android:textColor="@color/text_secondary"
                                android:layout_marginEnd="@dimen/spacing_sm" />

                            <TextView
                                android:id="@+id/tvMaCa"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="#BK-88392"
                                android:textSize="@dimen/text_body_md"
                                android:textColor="@color/primary"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <!-- Thời gian chơi -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_thoi_gian_choi"
                                android:textSize="@dimen/text_body_md"
                                android:textColor="@color/text_secondary"
                                android:layout_marginEnd="@dimen/spacing_sm" />

                            <TextView
                                android:id="@+id/tvThoiGianChoi"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="14:00 - 15:30 (1.5h)"
                                android:textSize="@dimen/text_body_md"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Chi tiết thanh toán -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chi tiết thanh toán"
                        android:textSize="@dimen/text_title_lg"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- Giá sân row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_gia_san"
                            android:textSize="@dimen/text_body_lg"
                            android:textColor="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tvGiaSan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="105,000 VNĐ"
                            android:textSize="@dimen/text_body_lg"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Dịch vụ thêm header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="@dimen/spacing_sm">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_dich_vu"
                            android:textSize="@dimen/text_body_lg"
                            android:textColor="@color/text_secondary" />

                        <Button
                            android:id="@+id/btnThemDichVu"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/button_height_sm"
                            android:background="@drawable/bg_btn_secondary"
                            android:text="@string/btn_them_dich_vu"
                            android:textColor="@color/primary"
                            android:textSize="@dimen/text_label_md"
                            android:paddingStart="@dimen/spacing_md"
                            android:paddingEnd="@dimen/spacing_md"
                            android:stateListAnimator="@null" />
                    </LinearLayout>

                    <!-- Service items container -->
                    <LinearLayout
                        android:id="@+id/containerDichVu"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <!-- Tổng cộng -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="@string/label_tong_cong"
                            android:textSize="@dimen/text_title_lg"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTongCong"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="105,000 VNĐ"
                            android:textSize="@dimen/text_title_lg"
                            android:textColor="@color/primary"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Phương thức thanh toán -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_lg"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="@dimen/card_elevation"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/card_padding">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Phương thức thanh toán"
                        android:textSize="@dimen/text_title_lg"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="3">

                        <!-- Tiền mặt -->
                        <LinearLayout
                            android:id="@+id/optionTienMat"
                            android:layout_width="0dp"
                            android:layout_height="72dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_payment_option_selected"
                            android:layout_marginEnd="@dimen/spacing_sm">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/ic_menu_send"
                                app:tint="@color/primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_tien_mat"
                                android:textSize="@dimen/text_label_md"
                                android:textColor="@color/primary"
                                android:textStyle="bold"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- Chuyển khoản -->
                        <LinearLayout
                            android:id="@+id/optionChuyenKhoan"
                            android:layout_width="0dp"
                            android:layout_height="72dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_payment_option"
                            android:layout_marginEnd="@dimen/spacing_sm">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/ic_menu_share"
                                app:tint="@color/text_secondary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_chuyen_khoan"
                                android:textSize="@dimen/text_label_md"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>

                        <!-- QR -->
                        <LinearLayout
                            android:id="@+id/optionQR"
                            android:layout_width="0dp"
                            android:layout_height="72dp"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="@drawable/bg_payment_option">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@android:drawable/ic_menu_camera"
                                app:tint="@color/text_secondary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/label_qr"
                                android:textSize="@dimen/text_label_md"
                                android:textColor="@color/text_secondary"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM ACTION -->
    <LinearLayout
        android:id="@+id/layoutActionBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@color/white"
        android:paddingStart="@dimen/margin_mobile"
        android:paddingEnd="@dimen/margin_mobile"
        android:paddingTop="@dimen/spacing_md"
        android:paddingBottom="@dimen/spacing_md"
        android:elevation="8dp"
        android:weightSum="2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnInHoaDon"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:background="@drawable/bg_btn_secondary"
            android:text="@string/btn_in_hoa_don"
            android:textColor="@color/primary"
            android:textSize="@dimen/text_body_md"
            android:textStyle="bold"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/btnXacNhanThanhToan"
            android:layout_width="0dp"
            android:layout_height="@dimen/button_height"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/spacing_sm"
            android:background="@drawable/bg_btn_primary"
            android:text="@string/btn_xac_nhan_thanh_toan"
            android:textColor="@color/white"
            android:textSize="@dimen/text_body_md"
            android:textStyle="bold"
            android:stateListAnimator="@null" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
