<?xml version="1.0" encoding="utf-8"?>
<!-- Màn hình Thống kê & Lịch sử — activity_thong_ke.xml -->
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- HEADER -->
    <FrameLayout
        android:id="@+id/layoutHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:paddingStart="@dimen/margin_mobile"
        android:paddingEnd="@dimen/margin_mobile"
        android:paddingTop="16dp"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Title row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/app_name"
                        android:textSize="@dimen/text_title_lg"
                        android:textColor="@color/white"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/facility_name"
                        android:textSize="@dimen/text_body_md"
                        android:textColor="#CCffffff" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_media_previous"
                    app:tint="@color/white"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:contentDescription="Back" />
            </LinearLayout>

            <!-- Filter Chips -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/chipNgay"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/chip_height"
                    android:background="@drawable/bg_chip_filter_active"
                    android:paddingStart="@dimen/chip_padding_horizontal"
                    android:paddingEnd="@dimen/chip_padding_horizontal"
                    android:text="@string/filter_ngay"
                    android:textSize="@dimen/text_body_md"
                    android:textColor="@color/tertiary"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginEnd="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/chipTuan"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/chip_height"
                    android:background="@drawable/bg_chip_filter_inactive"
                    android:paddingStart="@dimen/chip_padding_horizontal"
                    android:paddingEnd="@dimen/chip_padding_horizontal"
                    android:text="@string/filter_tuan"
                    android:textSize="@dimen/text_body_md"
                    android:textColor="@color/black"
                    android:gravity="center"
                    android:layout_marginEnd="@dimen/spacing_sm" />

                <TextView
                    android:id="@+id/chipThang"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/chip_height"
                    android:background="@drawable/bg_chip_filter_inactive"
                    android:paddingStart="@dimen/chip_padding_horizontal"
                    android:paddingEnd="@dimen/chip_padding_horizontal"
                    android:text="@string/filter_thang"
                    android:textSize="@dimen/text_body_md"
                    android:textColor="@color/black"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>
    </FrameLayout>

    <!-- Tab Bar: Thống kê / Lịch sử -->
    <LinearLayout
        android:id="@+id/layoutTabBar"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:background="@color/white"
        android:weightSum="2"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tabThongKe"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/tab_thong_ke"
            android:textSize="@dimen/text_body_md"
            android:textColor="@color/primary"
            android:textStyle="bold"
            android:gravity="center" />

        <TextView
            android:id="@+id/tabLichSu"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="@string/tab_lich_su"
            android:textSize="@dimen/text_body_md"
            android:textColor="@color/text_secondary"
            android:gravity="center" />
    </LinearLayout>

    <!-- Tab indicator -->
    <View
        android:id="@+id/tabIndicator"
        android:layout_width="0dp"
        android:layout_height="3dp"
        android:background="@color/primary"
        app:layout_constraintTop_toBottomOf="@id/layoutTabBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintWidth_percent="0.5" />

    <!-- SCROLL CONTENT -->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/tabIndicator"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/margin_mobile">

            <!-- Summary stats row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2"
                android:layout_marginBottom="@dimen/spacing_md">

                <!-- Tổng doanh thu -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/spacing_sm"
                    app:cardCornerRadius="@dimen/radius_lg"
                    app:cardElevation="@dimen/card_elevation"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/label_tong_doanh_thu"
                            android:textSize="@dimen/text_label_md"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="@dimen/spacing_xs" />

                        <TextView
                            android:id="@+id/tvTongDoanhThu"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2,450,000"
                            android:textSize="@dimen/text_headline_sm"
                            android:textColor="@color/primary"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VNĐ"
                            android:textSize="@dimen/text_label_md"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Số lượt đặt -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_sm"
                    app:cardCornerRadius="@dimen/radius_lg"
                    app:cardElevation="@dimen/card_elevation"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="@dimen/spacing_md">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Số lượt đặt"
                            android:textSize="@dimen/text_label_md"
                            android:textColor="@color/text_secondary"
                            android:layout_marginBottom="@dimen/spacing_xs" />

                        <TextView
                            android:id="@+id/tvSoLuotDat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="18"
                            android:textSize="@dimen/text_headline_sm"
                            android:textColor="@color/tertiary"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="lượt"
                            android:textSize="@dimen/text_label_md"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Section: Lịch sử hóa đơn -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_lich_su_hoa_don"
                android:textSize="@dimen/text_title_lg"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:layout_marginBottom="@dimen/spacing_md" />

            <!-- Invoice item 1 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardInvoice1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="2dp">

                            <TextView
                                android:id="@+id/tvInv1Court"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sân 01"
                                android:textSize="@dimen/text_body_lg"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold"
                                android:layout_marginEnd="@dimen/spacing_sm" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="@dimen/chip_height"
                                android:background="@drawable/bg_chip_available"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:text="Đã TT"
                                android:textSize="@dimen/text_label_md"
                                android:textColor="@color/status_available"
                                android:gravity="center" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvInv1Time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14:00 - 15:30 • Hôm nay"
                            android:textSize="@dimen/text_body_md"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:id="@+id/tvInv1Amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="105,000"
                            android:textSize="@dimen/text_body_lg"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VNĐ"
                            android:textSize="@dimen/text_label_md"
                            android:textColor="@color/text_hint" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Invoice item 2 -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardInvoice2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardCornerRadius="@dimen/radius_lg"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/card_padding"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="2dp">

                            <TextView
                                android:id="@+id/tvInv2Court"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Sân 03"
                                android:textSize="@dimen/text_body_lg"
                                android:textColor="@color/text_primary"
                                android:textStyle="bold"
                                android:layout_marginEnd="@dimen/spacing_sm" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="@dimen/chip_height"
                                android:background="@drawable/bg_chip_available"
                                android:paddingStart="8dp"
                                android:paddingEnd="8dp"
                                android:text="Đã TT"
                                android:textSize="@dimen/text_label_md"
                                android:textColor="@color/status_available"
                                android:gravity="center" />
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvInv2Time"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="10:00 - 12:00 • Hôm nay"
                            android:textSize="@dimen/text_body_md"
                            android:textColor="@color/text_secondary" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:id="@+id/tvInv2Amount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="140,000"
                            android:textSize="@dimen/text_body_lg"
                            android:textColor="@color/text_primary"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="VNĐ"
                            android:textSize="@dimen/text_label_md"
                            android:textColor="@color/text_hint" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- RecyclerView placeholder for more invoices -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHoaDon"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
