<?xml version="1.0" encoding="utf-8"?>
<!-- fragment_lich_su.xml — Tab Lịch sử đặt sân -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Lịch đặt sân"
        android:textSize="@dimen/text_title_lg"
        android:textColor="@color/text_primary"
        android:textStyle="bold"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="8dp" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tvEmptyLichSu"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Chưa có lịch đặt nào."
        android:textSize="@dimen/text_body_md"
        android:textColor="@color/text_hint"
        android:gravity="center"
        android:padding="32dp"
        android:visibility="visible" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvLichDat"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="12dp"
        android:nestedScrollingEnabled="true" />
</LinearLayout>
