<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="@dimen/card_padding">

        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginEnd="@dimen/spacing_md"
            android:background="@drawable/bg_icon_circle_green">

            <TextView
                android:id="@+id/txtMaSan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="01"
                android:textColor="@color/primary"
                android:textSize="@dimen/text_body_md"
                android:textStyle="bold" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtTenSan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Sân 01"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_body_lg"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtThongTinSan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cỏ nhân tạo | 70.000 VNĐ/giờ"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body_md" />
        </LinearLayout>

        <ImageView
            android:id="@+id/imgSuaSan"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_sua"
            android:padding="7dp"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="@color/primary" />

        <ImageView
            android:id="@+id/imgXoaSan"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/btn_xoa"
            android:padding="7dp"
            android:src="@android:drawable/ic_menu_delete"
            app:tint="@color/secondary" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
